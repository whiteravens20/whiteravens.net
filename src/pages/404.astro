---
import { Icon } from 'astro-icon/components';
import Base from '../layouts/Base.astro';
import Aurora from '../components/Aurora.astro';
import copy from '../content/copy.yml';
---

<Base title={`${copy.notFound.title} — White Ravens`}>
  <main id="main">
    <Aurora />
    <div class="wrap">
      <p class="code">404</p>
      <h1>{copy.notFound.title}</h1>
      <p class="body">{copy.notFound.body}</p>
      <a class="home" href="/">
        <Icon name="lucide:arrow-left" />
        {copy.notFound.home}
      </a>
    </div>
  </main>
</Base>

<style>
  main {
    position: relative;
    isolation: isolate;
    min-height: 100svh;
    display: grid;
    place-items: center;
    text-align: center;
  }

  .wrap {
    display: grid;
    justify-items: center;
    gap: var(--space-m);
  }

  .code {
    font-family: var(--font-display);
    font-size: var(--step-5);
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(100deg, var(--heading) 40%, var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  h1 {
    font-size: var(--step-2);
  }

  .body {
    color: var(--text-muted);
  }

  .home {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-m);
    padding: 0.8rem 1.5rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-full);
    background: var(--surface);
    color: var(--text);
    font-weight: 600;
    text-decoration: none;
    transition:
      transform var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease);
  }

  .home:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .home [data-icon] {
    width: 1.1em;
    height: 1.1em;
  }

  @media (prefers-reduced-motion: reduce) {
    .home:hover {
      transform: none;
    }
  }
</style>
